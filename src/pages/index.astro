---
import Layout from "@/layouts/main.astro"

const environmentTools = [
  {
    name: "SoloTerm",
    url: "https://soloterm.com",
    domain: "soloterm.com",
    description:
      "Run Claude Code, Codex, and Gemini CLI alongside your local dev services.",
  },
  {
    name: "cmux",
    url: "https://cmux.dev",
    domain: "cmux.dev",
    description:
      "A native macOS terminal built for multitasking with AI coding agents.",
  },
  {
    name: "Conductor",
    url: "https://conductor.build",
    domain: "conductor.build",
    description:
      "Run parallel Codex and Claude Code agents in isolated local workspaces.",
  },
  {
    name: "Superset",
    url: "https://superset.sh",
    domain: "superset.sh",
    description:
      "Launch and manage many parallel coding agents on your own machine.",
  },
  {
    name: "dmux",
    url: "https://dmux.ai",
    domain: "dmux.ai",
    description:
      "A tmux pane manager for parallel AI development sessions with worktrees.",
  },
  {
    name: "Codex GUI",
    url: "https://openai.com/codex/",
    domain: "openai.com",
    description:
      "OpenAI's web app for coding with agents that can complete tasks end to end.",
  },
  {
    name: "OpenCode Desktop",
    url: "https://opencode.ai",
    domain: "opencode.ai",
    description:
      "Open source AI coding agent you can run in the terminal, IDE, or desktop app.",
  },
  {
    name: "T3 Code",
    url: "https://t3.codes",
    domain: "t3.codes",
    description: "A focused AI coding environment positioned as a fast way to ship.",
  },
]

const cliTuiTools = [
  {
    name: "Aider",
    url: "https://aider.chat/",
    domain: "aider.chat",
    description: "Open source AI pair programmer that edits code directly in your repo.",
  },
  {
    name: "Amp",
    url: "https://ampcode.com/",
    domain: "ampcode.com",
    description: "Terminal-first AI coding assistant for running agentic development workflows.",
  },
  {
    name: "Claude Code",
    url: "https://code.claude.com/docs/en/overview",
    domain: "claude.com",
    description: "Anthropic's terminal coding agent for codebase-aware edits and execution.",
  },
  {
    name: "Cline CLI",
    url: "https://cline.bot/cli",
    domain: "cline.bot",
    description: "Command-line interface for running Cline's coding agent from your terminal.",
  },
  {
    name: "Codex CLI",
    url: "https://developers.openai.com/codex/cli/",
    domain: "openai.com",
    description: "OpenAI's command-line coding agent for terminal-native software tasks.",
  },
  {
    name: "Copilot CLI",
    url: "https://github.com/features/copilot/cli",
    domain: "github.com",
    description: "GitHub Copilot in the terminal for generating and explaining shell commands.",
  },
  {
    name: "Cursor CLI",
    url: "https://cursor.com/cli",
    domain: "cursor.com",
    description: "Cursor's CLI for running coding and agent workflows outside the editor.",
  },
  {
    name: "Kiro CLI",
    url: "https://kiro.dev/cli/",
    domain: "kiro.dev",
    description: "Kiro command-line tooling for building and shipping with AI coding agents.",
  },
  {
    name: "OpenCode CLI",
    url: "https://opencode.ai/docs/cli/",
    domain: "opencode.ai",
    description: "OpenCode's CLI for running coding sessions from the terminal.",
  },
  {
    name: "Pi Agent",
    url: "https://shittycodingagent.ai/",
    domain: "shittycodingagent.ai",
    description: "Terminal-native AI coding agent for command-line development workflows.",
  },
]

const tools = [
  ...environmentTools.map((tool) => ({ ...tool, category: "environment" })),
  ...cliTuiTools.map((tool) => ({ ...tool, category: "cli-tui" })),
].sort((a, b) => a.name.localeCompare(b.name))

const filterOptions = [
  { id: "all", label: "All", count: tools.length },
  {
    id: "environment",
    label: "ADE",
    count: tools.filter((tool) => tool.category === "environment").length,
  },
  {
    id: "cli-tui",
    label: "CLI/TUI",
    count: tools.filter((tool) => tool.category === "cli-tui").length,
  },
]

const issueTitle = "Add missing AI tool: [Tool Name]"
const issueBody = `## Tool to add
- Name:
- Website:
- GitHub repo:

## Suggested prompt
Please add [TOOL NAME] to the tool list.

Requirements:
- Pull a short one-line description from the official site.
`
const newIssueUrl = `https://github.com/cruzluna/ai-tools/issues/new?title=${encodeURIComponent(issueTitle)}&body=${encodeURIComponent(issueBody)}`
---

<Layout title="AI Agent Environments">
  <main class="min-h-svh w-full bg-black text-white">
    <div class="mx-auto w-full max-w-6xl px-6 py-10 sm:px-10 sm:py-14">
      <header class="mb-8 border-b border-zinc-900 pb-6">
        <div class="space-y-4">
          <div class="space-y-2">
            <p class="text-xs tracking-[0.2em] text-zinc-500 uppercase">Featured Tools</p>
            <h1 class="text-3xl font-medium tracking-tight sm:text-4xl">Agent Development Environments</h1>
            <p class="max-w-2xl text-base text-zinc-400">Brief picks for building with AI agents.</p>
          </div>

          <div data-controls-root class="space-y-3 text-xs tracking-[0.2em] uppercase">
            <div class="flex flex-wrap items-center gap-2">
              <p class="text-zinc-600">View:</p>
              <div class="inline-flex items-center gap-2">
                <button
                  type="button"
                  data-view-button="list"
                  aria-pressed="true"
                  class="text-zinc-100 underline decoration-zinc-400 underline-offset-4 transition-colors hover:text-zinc-200 focus-visible:outline-none"
                >
                  List
                </button>
                <span aria-hidden="true" class="text-zinc-700">/</span>
                <button
                  type="button"
                  data-view-button="grid"
                  aria-pressed="false"
                  class="text-zinc-500 no-underline transition-colors hover:text-zinc-200 focus-visible:outline-none"
                >
                  Grid
                </button>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-2">
              <p class="text-zinc-600">Filter:</p>
              <div class="inline-flex flex-wrap items-center gap-2">
                {
                  filterOptions.map((option, index) => (
                    <button
                      type="button"
                      data-filter-button={option.id}
                      aria-pressed={index === 0 ? "true" : "false"}
                      class:list={[
                        "rounded-full border px-3 py-1 transition-colors hover:text-zinc-200 focus-visible:outline-none",
                        index === 0 ? "border-zinc-300 text-zinc-100" : "border-zinc-700 text-zinc-500",
                      ]}
                    >
                      {option.label} ({option.count})
                    </button>
                  ))
                }
              </div>
              <p data-tools-count class="ml-1 text-zinc-600">{tools.length} tools</p>
            </div>
          </div>
        </div>
      </header>

      <section data-view-panel="list" aria-label="Tools list view" class="border border-zinc-800">
        <ul role="list" class="divide-y divide-zinc-800">
          {
            tools.map((tool, index) => (
              <li data-tool-item data-category={tool.category}>
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noreferrer"
                  class="group flex flex-col gap-4 px-4 py-5 transition-colors hover:bg-zinc-950 sm:grid sm:grid-cols-[minmax(0,1.4fr)_minmax(0,2fr)_auto] sm:items-center sm:gap-6 sm:px-6"
                >
                  <div class="flex min-w-0 items-center gap-3">
                    <p data-list-number class="w-7 shrink-0 text-xs tabular-nums text-zinc-600">
                      {String(index + 1).padStart(2, "0")}
                    </p>
                    <span class="flex size-10 shrink-0 items-center justify-center border border-zinc-800 bg-zinc-950">
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${tool.domain}&sz=128`}
                        alt={`${tool.name} logo`}
                        loading="lazy"
                        class="size-6 grayscale"
                      />
                    </span>
                    <div class="min-w-0">
                      <p class="truncate text-base tracking-tight">{tool.name}</p>
                      <p class="truncate text-xs text-zinc-500">{tool.url.replace("https://", "")}</p>
                    </div>
                  </div>

                  <p class="text-sm leading-relaxed text-zinc-400">{tool.description}</p>

                  <p class="text-xs tracking-[0.2em] text-zinc-600 uppercase">
                    {tool.category === "environment" ? "ADE" : "CLI/TUI"}
                  </p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section data-view-panel="grid" aria-label="Tools grid view" class="hidden grid gap-4 sm:grid-cols-2">
        {
          tools.map((tool) => (
            <a
              data-tool-item
              data-category={tool.category}
              href={tool.url}
              target="_blank"
              rel="noreferrer"
              class="group flex min-h-64 flex-col justify-between border border-zinc-800 bg-black p-6 transition-colors hover:border-zinc-600"
            >
              <div>
                <div class="mb-6 flex items-center gap-4">
                  <span class="flex size-12 shrink-0 items-center justify-center border border-zinc-800 bg-zinc-950">
                    <img
                      src={`https://www.google.com/s2/favicons?domain=${tool.domain}&sz=128`}
                      alt={`${tool.name} logo`}
                      loading="lazy"
                      class="size-7 grayscale"
                    />
                  </span>
                  <div class="min-w-0">
                    <p class="truncate text-sm text-zinc-500">{tool.url.replace("https://", "")}</p>
                    <p class="text-2xl leading-tight tracking-tight">{tool.name}</p>
                    <p class="mt-1 text-xs tracking-[0.2em] text-zinc-600 uppercase">
                      {tool.category === "environment" ? "ADE" : "CLI/TUI"}
                    </p>
                  </div>
                </div>
                <p class="text-lg leading-relaxed text-zinc-400">{tool.description}</p>
              </div>
            </a>
          ))
        }
      </section>

      <footer class="mt-12 flex flex-wrap items-center justify-between gap-3 border-t border-zinc-900 pt-6">
        <p class="text-xs text-zinc-600">
          site by:
          <a
            href="https://www.cruzluna.dev/"
            target="_blank"
            rel="noreferrer"
            class="ml-1 text-zinc-400 underline underline-offset-4 hover:text-zinc-200"
          >
            cruzluna.dev
          </a>
        </p>
        <a
          href={newIssueUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="Missing? Opens GitHub in a new tab"
          title="Opens GitHub in a new tab"
          class="inline-flex items-center gap-1 border border-zinc-700 px-4 py-2 text-sm text-zinc-300 transition-colors hover:border-zinc-500 hover:text-zinc-100 focus-visible:outline-none"
        >
          <span>Missing?</span>
          <span aria-hidden="true">↗</span>
        </a>
      </footer>
    </div>

    <script>
      const VIEW_STORAGE_KEY = "tools-view"
      const FILTER_STORAGE_KEY = "tools-filter"

      const controlsRoot = document.querySelector("[data-controls-root]")
      const listPanel = document.querySelector('[data-view-panel="list"]')
      const gridPanel = document.querySelector('[data-view-panel="grid"]')

      if (controlsRoot && listPanel && gridPanel) {
        const viewButtons = Array.from(controlsRoot.querySelectorAll("[data-view-button]"))
        const filterButtons = Array.from(controlsRoot.querySelectorAll("[data-filter-button]"))
        const listItems = Array.from(listPanel.querySelectorAll("[data-tool-item]"))
        const gridItems = Array.from(gridPanel.querySelectorAll("[data-tool-item]"))
        const countLabel = document.querySelector("[data-tools-count]")

        const applyButtonState = (buttons, activeValue, key) => {
          for (const button of buttons) {
            const isActive = button.dataset[key] === activeValue
            button.setAttribute("aria-pressed", isActive ? "true" : "false")

            button.classList.toggle("text-zinc-100", isActive)
            button.classList.toggle("text-zinc-500", !isActive)
            button.classList.toggle("border-zinc-300", isActive)
            button.classList.toggle("border-zinc-700", !isActive)

            if (key === "viewButton") {
              button.classList.toggle("underline", isActive)
              button.classList.toggle("decoration-zinc-400", isActive)
              button.classList.toggle("underline-offset-4", isActive)
              button.classList.toggle("no-underline", !isActive)
            }
          }
        }

        const applyView = (view) => {
          const useGrid = view === "grid"
          listPanel.classList.toggle("hidden", useGrid)
          gridPanel.classList.toggle("hidden", !useGrid)
          applyButtonState(viewButtons, view, "viewButton")
        }

        const applyFilter = (filter) => {
          let visibleCount = 0
          let visibleIndex = 1

          for (const item of listItems) {
            const isVisible = filter === "all" || item.dataset.category === filter
            item.classList.toggle("hidden", !isVisible)

            if (isVisible) {
              const number = item.querySelector("[data-list-number]")
              if (number) {
                number.textContent = String(visibleIndex).padStart(2, "0")
              }
              visibleIndex += 1
              visibleCount += 1
            }
          }

          for (const item of gridItems) {
            const isVisible = filter === "all" || item.dataset.category === filter
            item.classList.toggle("hidden", !isVisible)
          }

          if (countLabel) {
            countLabel.textContent = `${visibleCount} tools`
          }

          applyButtonState(filterButtons, filter, "filterButton")
        }

        const savedView = localStorage.getItem(VIEW_STORAGE_KEY)
        const savedFilter = localStorage.getItem(FILTER_STORAGE_KEY)

        const initialView = savedView === "grid" ? "grid" : "list"
        const initialFilter =
          savedFilter === "environment" || savedFilter === "cli-tui" ? savedFilter : "all"

        applyFilter(initialFilter)
        applyView(initialView)

        for (const button of viewButtons) {
          button.addEventListener("click", () => {
            const nextView = button.dataset.viewButton === "grid" ? "grid" : "list"
            applyView(nextView)
            localStorage.setItem(VIEW_STORAGE_KEY, nextView)
          })
        }

        for (const button of filterButtons) {
          button.addEventListener("click", () => {
            const nextFilter = button.dataset.filterButton ?? "all"
            applyFilter(nextFilter)
            localStorage.setItem(FILTER_STORAGE_KEY, nextFilter)
          })
        }
      }
    </script>
  </main>
</Layout>
