---
import "@/styles/global.css"

const {
  title = "AI Tools",
  description = "Minimal index of AI agent development environments.",
  ogImage = "/og-image.png",
  ogImageAlt,
} = Astro.props

// X/Twitter requires absolute URLs for og:image - use site config or request origin
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? ""
const requestOrigin = Astro.url.origin
const isLocalhost = /^https?:\/\/localhost(?::\d+)?$/i.test(requestOrigin)
const baseOrigin = siteOrigin || (isLocalhost ? "" : requestOrigin)
const absoluteOgImage =
  ogImage.startsWith("http://") || ogImage.startsWith("https://")
    ? ogImage
    : baseOrigin
      ? new URL(ogImage, baseOrigin).toString()
      : ogImage
const imageAlt = ogImageAlt ?? title
---

<html lang="en" class="bg-black">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
  </head>
  <body class="overflow-x-hidden bg-black text-white">
    <slot />
  </body>
</html>
